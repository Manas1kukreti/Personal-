ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://ledgerflow:ledgerflow@localhost:5433/ledgerflow
APP_NAME=LedgerFlow Analytics API
UPLOAD_DIR=./storage/uploads
MAX_PREVIEW_ROWS=50
MAX_UPLOAD_SIZE_MB=10
JWT_SECRET_KEY=local-development-secret-change-before-deploy
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_BASE_URL=http://localhost:5173
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=local-dev-admin-password
DEFAULT_ADMIN_NAME=LedgerFlow Admin
AGENT_EMAIL=
AGENT_PASSWORD=
AGENT_NAME=LedgerFlow Posting Agent
EMAILS_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@ledgerflow.local
SMTP_TLS=true
